{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Purchases Schema",
  "definitions": {
    "Supplier": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "name": { "type": "string", "minLength": 1 },
        "phone": { "type": ["string", "null"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "deletedAt": { "type": ["string", "null"] }
      }
    },
    "PurchaseOrder": {
      "type": "object",
      "required": ["id", "supplierId", "status", "totalUsd", "createdBy", "createdAt", "updatedAt"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "supplierId": { "type": "string", "format": "uuid" },
        "status": { "type": "string", "enum": ["draft", "confirmed", "partially_received", "received", "cancelled"] },
        "totalUsd": { "type": "number", "minimum": 0 },
        "notes": { "type": ["string", "null"] },
        "createdBy": { "type": "string", "format": "uuid" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "deletedAt": { "type": ["string", "null"] }
      }
    },
    "PurchaseOrderItem": {
      "type": "object",
      "required": ["id", "orderId", "productId", "quantity", "costUsdPerUnit", "receivedQuantity", "totalUsd"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "orderId": { "type": "string", "format": "uuid" },
        "productId": { "type": "string", "format": "uuid" },
        "quantity": { "type": "integer", "minimum": 1 },
        "costUsdPerUnit": { "type": "number", "minimum": 0.01 },
        "receivedQuantity": { "type": "integer", "minimum": 0 },
        "totalUsd": { "type": "number", "minimum": 0.01 },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
