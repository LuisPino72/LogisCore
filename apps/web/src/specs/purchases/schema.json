{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Purchases Schema — solo referencial, la fuente de verdad son los schemas Zod en index.ts",
  "definitions": {
    "Supplier": {
      "type": "object",
      "required": ["id", "name", "createdAt"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "name": { "type": "string", "minLength": 1, "maxLength": 25 },
        "phone": { "type": "string", "maxLength": 50 },
        "createdAt": { "type": "string", "format": "date-time" },
        "deletedAt": { "type": "string", "format": "date-time" }
      }
    },
    "CreateSupplierInput": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 25 },
        "phone": { "type": "string", "maxLength": 50 }
      },
      "additionalProperties": false
    },
    "PurchaseOrderStatus": {
      "type": "string",
      "enum": ["draft", "confirmed", "partially_received", "received", "cancelled"]
    },
    "PurchaseOrder": {
      "type": "object",
      "required": ["id", "supplierId", "status", "totalUsd", "createdBy", "createdAt", "updatedAt"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "supplierId": { "type": "string", "format": "uuid" },
        "status": { "$ref": "#/definitions/PurchaseOrderStatus" },
        "totalUsd": { "type": "number", "minimum": 0 },
        "notes": { "type": "string", "maxLength": 500 },
        "createdBy": { "type": "string", "format": "uuid" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "deletedAt": { "type": "string", "format": "date-time" }
      }
    },
    "PurchaseOrderItem": {
      "type": "object",
      "required": ["id", "orderId", "productId", "productName", "quantity", "costUsdPerUnit", "receivedQuantity", "totalUsd", "createdAt"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "orderId": { "type": "string", "format": "uuid" },
        "productId": { "type": "string", "format": "uuid" },
        "presentationId": { "type": "string", "format": "uuid" },
        "unitMultiplier": { "type": "number", "exclusiveMinimum": 0 },
        "productName": { "type": "string" },
        "quantity": { "type": "number", "exclusiveMinimum": 0 },
        "costUsdPerUnit": { "type": "number", "exclusiveMinimum": 0, "maximum": 99999.99 },
        "receivedQuantity": { "type": "number", "minimum": 0 },
        "totalUsd": { "type": "number", "exclusiveMinimum": 0 },
        "createdAt": { "type": "string", "format": "date-time" },
        "deletedAt": { "type": "string", "format": "date-time" }
      }
    },
    "CreatePurchaseOrderInput": {
      "type": "object",
      "required": ["supplierId", "items"],
      "properties": {
        "supplierId": { "type": "string", "format": "uuid" },
        "notes": { "type": "string", "maxLength": 500 },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["productId", "quantity", "totalCostUsd"],
            "properties": {
              "productId": { "type": "string", "format": "uuid" },
              "presentationId": { "type": "string", "format": "uuid" },
              "unitMultiplier": { "type": "number", "exclusiveMinimum": 0 },
              "quantity": { "type": "number", "exclusiveMinimum": 0 },
              "totalCostUsd": { "type": "number", "exclusiveMinimum": 0 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "ReceivePurchaseOrderInput": {
      "type": "object",
      "required": ["orderId", "items"],
      "properties": {
        "orderId": { "type": "string", "format": "uuid" },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["itemId", "receivedQuantity"],
            "properties": {
              "itemId": { "type": "string", "format": "uuid" },
              "receivedQuantity": { "type": "integer", "minimum": 0 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  }
}
