// ============================================================
// LogisCore ERP — Database Schema
// Fuente de verdad: supabase/migrations/
//
// Reglas:
// - dinero = NUMERIC(19,2) en Postgres, number en TS
// - soft_delete = deleted_at timestamptz nullable
// - multi-tenant = todas las tablas tienen tenant_id
//   (en cloud UUID, en local slug)
// ============================================================

Table tenants {
  id uuid [pk]
  slug text [unique, not null]
  name text [not null]
  rif text [not null]
  direccion text
  telefono text
  created_at timestamptz [default: `now()`]
  deleted_at timestamptz
}

Table user_roles {
  id uuid [pk]
  user_id uuid [not null, ref: > auth.users.id]
  tenant_id uuid [ref: > tenants.id]
  role text [not null]
  created_at timestamptz [default: `now()`]
  deleted_at timestamptz
}

Table subscriptions {
  id uuid [pk]
  tenant_id uuid [not null, ref: > tenants.id]
  plan text [not null, default: 'basic']
  status text [not null, default: 'active']
  started_at timestamptz [default: `now()`]
  expires_at timestamptz
  updated_at timestamptz [default: `now()`]
  deleted_at timestamptz
}

Table audit_trail {
  id uuid [pk]
  event_name text [not null]
  event_module text [not null]
  user_id uuid [ref: > auth.users.id]
  tenant_id uuid [ref: > tenants.id] -- nullable: admin users may not have tenant context
  payload jsonb [default: '{}']
  severity text [not null, default: 'INFO']
  created_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
}

Table outbox {
  id uuid [pk]
  event text [not null]
  module text [not null]
  payload jsonb [default: '{}']
  status text [not null, default: 'pending']
  retries int [not null, default: 0]
  last_error text
  next_retry_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  processed_at timestamptz
}

Table exchange_rates {
  id uuid [pk]
  tenant_id uuid [not null, unique, ref: > tenants.id]
  rate numeric(19,4) [not null]
  source text [not null]
  fetched_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  deleted_at timestamptz
}

// ===== INVENTORY (INV-007) =====

Table products {
  id uuid [pk]
  tenant_id uuid [not null, ref: > tenants.id]
  name text [not null]
  sku text [not null]
  price_usd numeric(19,2) [not null]
  category_id uuid [ref: > categories.id]
  is_weighted boolean [not null, default: false]
  is_taxable boolean [not null, default: true]
  is_sellable boolean [not null, default: true]
  is_ingredient boolean [not null, default: false]
  unit text [not null]
  stock integer [not null, default: 0]
  stock_min integer
  stock_in_carts integer [not null, default: 0]
  image_url text
  cost_price numeric(12,4)
  product_type text [not null, default: 'materia_prima']
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
  deleted_at timestamptz
}

Table categories {
  id uuid [pk]
  tenant_id uuid [ref: > tenants.id]         -- nullable for global predefined categories
  name text [not null]
  is_predefined boolean [not null, default: false]
  default_image_url text
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
  deleted_at timestamptz
}

Table image_library {
  id uuid [pk]
  name text [not null]
  category_id uuid [ref: > categories.id]
  image_url text [not null]
  is_default boolean [not null, default: false]
  sort_order integer [not null, default: 0]
  tenant_id uuid [ref: > tenants.id]
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
  deleted_at timestamptz
}

Table inventory_movements {
  id uuid [pk]
  tenant_id uuid [not null, ref: > tenants.id]
  product_id uuid [not null, ref: > products.id]
  user_id uuid [not null, ref: > auth.users.id]
  type text [not null]
  quantity integer [not null]
  previous_stock integer [not null]
  new_stock integer [not null]
  reason text
  created_at timestamptz [default: `now()`]
  deleted_at timestamptz
}

Table inventory_lots {
  id uuid [pk]
  tenant_id uuid [not null, ref: > tenants.id]
  product_id uuid [not null, ref: > products.id]
  quantity_added integer [not null]
  remaining_quantity integer [not null]
  cost_usd_per_unit numeric(19,2)
  version integer [not null, default: 1]
  source_movement_id uuid [ref: > inventory_movements.id]
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
  deleted_at timestamptz
}

Table suppliers {
  id uuid [pk]
  tenant_id uuid [not null, ref: > tenants.id]
  name text [not null]
  phone text
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
  deleted_at timestamptz
}

Table purchase_orders {
  id uuid [pk]
  tenant_id uuid [not null, ref: > tenants.id]
  supplier_id uuid [not null, ref: > suppliers.id]
  status text [not null, default: 'draft']
  total_usd numeric(19,2) [not null, default: 0]
  notes text
  created_by uuid [not null, ref: > auth.users.id]
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
  deleted_at timestamptz
}

Table purchase_order_items {
  id uuid [pk]
  order_id uuid [not null, ref: > purchase_orders.id]
  tenant_id uuid [not null, ref: > tenants.id]
  product_id uuid [not null, ref: > products.id]
  presentation_id uuid [null, ref: > product_presentations.id]
  unit_multiplier decimal(10,2) [not null, default: 1]
  product_name text
  quantity integer [not null]
  cost_usd_per_unit numeric(19,2) [not null]
  received_quantity integer [not null, default: 0]
  total_usd numeric(19,2) [not null]
  created_at timestamptz [default: `now()`]
  deleted_at timestamptz
}

// ===== POS (SALES) =====

Table sales {
  id uuid [pk]
  tenant_id uuid [not null, ref: > tenants.id]
  user_id uuid [not null, ref: > auth.users.id]
  payment_method text [not null]
  subtotal_bs numeric(19,2) [not null]
  igtf_bs numeric(19,2) [not null, default: 0]
  iva_bs numeric(19,2) [not null, default: 0]
  total_bs numeric(19,2) [not null]
  exchange_rate numeric(19,4) [not null]
  status text [not null, default: 'completed']
  voided_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
  // PLAN-112: cliente asociado (opcional). SET NULL al eliminar cliente (preserva venta).
  customer_id uuid [ref: > customers.id, note: 'ON DELETE SET NULL']
}

Table sale_items {
  id uuid [pk]
  sale_id uuid [not null, ref: > sales.id]
  tenant_id uuid [not null, ref: > tenants.id]
  product_id uuid [not null, ref: > products.id]
  product_name text
  product_sku text
  quantity numeric(19,2) [not null]
  unit_price_usd numeric(19,2) [not null]
  total_price_usd numeric(19,2) [not null]
  cost_usd_per_unit numeric(19,2)
  is_weighted boolean [not null, default: false]
  unit text
  created_at timestamptz [not null, default: `now()`]
}

Table cash_registers {
  id uuid [pk]
  tenant_id uuid [not null, ref: > tenants.id]
  is_open boolean [not null, default: false]
  opened_by uuid [ref: > auth.users.id]
  opened_at timestamptz
  opening_balance_bs numeric(19,2)
  opening_rate numeric(19,2)
  closed_by uuid [ref: > auth.users.id]
  closed_at timestamptz
  closing_balance_bs numeric(19,2)
  closing_rate numeric(19,2)
  expected_closing_bs numeric(19,2)
  difference_bs numeric(19,2)
  total_sales_count integer [not null, default: 0]
  total_sales_bs numeric(19,2) [not null, default: 0]
  total_igtf_bs numeric(19,2) [not null, default: 0]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz
  deleted_at timestamptz
}

// Refs
Ref: user_roles.tenant_id - tenants.id
Ref: subscriptions.tenant_id - tenants.id
Ref: audit_trail.tenant_id - tenants.id
Ref: exchange_rates.tenant_id - tenants.id
Ref: products.tenant_id - tenants.id
Ref: products.category_id - categories.id
Ref: categories.tenant_id - tenants.id
Ref: image_library.tenant_id - tenants.id
Ref: image_library.category_id - categories.id
Ref: inventory_movements.tenant_id - tenants.id
Ref: inventory_movements.product_id - products.id
Ref: inventory_movements.user_id - auth.users.id
Ref: inventory_lots.tenant_id - tenants.id
Ref: inventory_lots.product_id - products.id
Ref: inventory_lots.source_movement_id - inventory_movements.id
Ref: suppliers.tenant_id - tenants.id
Ref: purchase_orders.tenant_id - tenants.id
Ref: purchase_orders.supplier_id - suppliers.id
Ref: purchase_order_items.order_id - purchase_orders.id
Ref: purchase_order_items.tenant_id - tenants.id
Ref: purchase_order_items.product_id - products.id
Ref: sales.tenant_id - tenants.id
Ref: sales.user_id - auth.users.id
Ref: sale_items.sale_id - sales.id
Ref: sale_items.tenant_id - tenants.id
Ref: sale_items.product_id - products.id
Ref: cash_registers.tenant_id - tenants.id

// ===== PRODUCTION (PLAN-PRODUCTION) =====

Table recipes {
  id uuid [pk]
  tenant_id uuid [not null, ref: > tenants.id]
  name text [not null]
  product_id uuid [not null, ref: > products.id]
  mode text [not null, default: 'batch']
  yield_quantity integer [not null, default: 1]
  yield_unit text [not null, default: 'unidad']
  waste_pct numeric(5,2) [not null, default: 0]
  is_active boolean [not null, default: true]
  notes text
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
  deleted_at timestamptz
}

Table recipe_lines {
  id uuid [pk]
  tenant_id uuid [not null, ref: > tenants.id]
  recipe_id uuid [not null, ref: > recipes.id]
  product_id uuid [not null, ref: > products.id]
  quantity numeric(19,4) [not null]
  unit text [not null, default: 'unidad']
  sort_order integer [not null, default: 0]
  created_at timestamptz [default: `now()`]
  deleted_at timestamptz

  Note: 'PLAN-115: recipe_lines_quantity_positive_check CHECK (quantity > 0)'
}

Table production_orders {
  id uuid [pk]
  tenant_id uuid [not null, ref: > tenants.id]
  recipe_id uuid [not null, ref: > recipes.id]
  product_id uuid [not null, ref: > products.id]
  batch_count integer [not null, default: 1]
  quantity_target integer [not null]
  // PLAN-115: NOT NULL DEFAULT 0 + CHECK >= 0 (alineado con TS spec)
  quantity_produced integer [not null, default: 0]
  status text [not null, default: 'draft']
  planned_date date
  started_at timestamptz
  completed_at timestamptz
  waste_notes text
  created_by uuid [not null, ref: > auth.users.id]
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
  deleted_at timestamptz
  total_cost numeric(12,4)
  cost_per_unit numeric(12,4)

  Note: 'PLAN-115 CHECKs: production_orders_batch_count_positive_check CHECK (batch_count > 0), production_orders_quantity_produced_nonneg_check CHECK (quantity_produced >= 0). Indices: idx_production_orders_tenant_status, idx_production_orders_tenant_deleted.'
}

// Refs adicionales para producción
Ref: recipes.tenant_id - tenants.id
Ref: recipes.product_id - products.id
Ref: recipe_lines.tenant_id - tenants.id
Ref: recipe_lines.recipe_id - recipes.id
// PLAN-115 (BD-CRIT-5): FK recipe_lines.recipe_id usa NO ACTION (default Postgres).
// Decision de producto 2026-06-07: SOFT-DELETE-ONLY. recipes SIEMPRE se eliminan
// via soft-delete (deleted_at). Hard-delete NO es flujo soportado en LogisCore.
// Consistente con resto del ERP (sales, products, etc). Si en el futuro se requiere
// hard-delete (purgas reales), ALTER FK ON DELETE CASCADE en migracion forward-only.
Ref: recipe_lines.product_id - products.id
Ref: production_orders.tenant_id - tenants.id
Ref: production_orders.recipe_id - recipes.id

// PLAN-112 (C3): tabla customers del modulo CRM (ya aplicada en BD, antes solo existia
// en Memoria/PROYECTO/Archivo/20260602-PLAN-CUSTOMER-001/migrations/).
Table customers {
  id uuid [pk, default: `gen_random_uuid()`]
  tenant_id uuid [not null, ref: > tenants.id, note: 'ON DELETE NO ACTION (preservar historial)']
  name text [not null]
  phone text
  address text
  credit_limit numeric(12,2) [default: 0]
  balance numeric(12,2) [not null, default: 0]
  notes text
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
  // AUDIT-017: cedula (V/E/J/P + 6-8 digitos) agregada en sesion 97
  // No agregada al SQL archivado original porque se migro como columna sin constraint CHECK
  // en la migracion real. Plan-112 (NEW-2) lo agregara en migracion idempotente.
  cedula text
  Indexes {
    (tenant_id) [name: 'idx_customers_tenant_id']
    (tenant_id, deleted_at) [name: 'idx_customers_tenant_deleted']
    (tenant_id, name) [name: 'idx_customers_name']
  }
}
Ref: production_orders.product_id - products.id
Ref: production_orders.created_by - auth.users.id
