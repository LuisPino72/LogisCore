// ============================================================
// LogisCore ERP — Database Schema
// Fuente de verdad: supabase/migrations/
//
// Reglas:
// - dinero = NUMERIC(19,2) en Postgres, number en TS
// - soft_delete = deleted_at timestamptz nullable
// - multi-tenant = todas las tablas tienen tenant_id
//   (en cloud UUID, en local slug)
// ============================================================

Table tenants {
  id uuid [pk]
  slug text [unique, not null]
  name text [not null]
  rif text [not null]
  direccion text
  telefono text
  created_at timestamptz [default: `now()`]
  deleted_at timestamptz
}

Table user_roles {
  id uuid [pk]
  user_id uuid [not null, ref: > auth.users.id]
  tenant_id uuid [ref: > tenants.id]
  role text [not null]
  created_at timestamptz [default: `now()`]
  deleted_at timestamptz
}

Table subscriptions {
  id uuid [pk]
  tenant_id uuid [not null, ref: > tenants.id]
  plan text [not null, default: 'basic']
  status text [not null, default: 'active']
  started_at timestamptz [default: `now()`]
  expires_at timestamptz
  updated_at timestamptz [default: `now()`]
  deleted_at timestamptz
}

Table audit_trail {
  id uuid [pk]
  event_name text [not null]
  event_module text [not null]
  user_id uuid [ref: > auth.users.id]
  tenant_id uuid [ref: > tenants.id] -- nullable: admin users may not have tenant context
  payload jsonb [default: '{}']
  severity text [not null, default: 'INFO']
  created_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
}

Table outbox {
  id uuid [pk]
  event text [not null]
  module text [not null]
  payload jsonb [default: '{}']
  status text [not null, default: 'pending']
  retries int [not null, default: 0]
  last_error text
  next_retry_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  processed_at timestamptz
}

Table exchange_rates {
  id uuid [pk]
  tenant_id uuid [not null, unique, ref: > tenants.id]
  rate numeric(19,4) [not null]
  source text [not null]
  fetched_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  deleted_at timestamptz
}

// ===== INVENTORY (INV-007) =====

Table products {
  id uuid [pk]
  tenant_id uuid [not null, ref: > tenants.id]
  name text [not null]
  sku text [not null]
  price_usd numeric(19,2) [not null]
  category_id uuid [ref: > categories.id]
  is_weighted boolean [not null, default: false]
  is_taxable boolean [not null, default: true]
  is_sellable boolean [not null, default: true]
  unit text [not null]
  stock integer [not null, default: 0]
  stock_min integer
  image_url text
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
  deleted_at timestamptz
}

Table categories {
  id uuid [pk]
  tenant_id uuid [ref: > tenants.id]         -- nullable for global predefined categories
  name text [not null]
  is_predefined boolean [not null, default: false]
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
  deleted_at timestamptz
}

Table inventory_movements {
  id uuid [pk]
  tenant_id uuid [not null, ref: > tenants.id]
  product_id uuid [not null, ref: > products.id]
  user_id uuid [not null, ref: > auth.users.id]
  type text [not null]
  quantity integer [not null]
  previous_stock integer [not null]
  new_stock integer [not null]
  reason text
  created_at timestamptz [default: `now()`]
  deleted_at timestamptz
}

Table inventory_lots {
  id uuid [pk]
  tenant_id uuid [not null, ref: > tenants.id]
  product_id uuid [not null, ref: > products.id]
  quantity_added integer [not null]
  remaining_quantity integer [not null]
  cost_usd_per_unit numeric(19,2)
  version integer [not null, default: 1]
  source_movement_id uuid [ref: > inventory_movements.id]
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
  deleted_at timestamptz
}

Table suppliers {
  id uuid [pk]
  tenant_id uuid [not null, ref: > tenants.id]
  name text [not null]
  phone text
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
  deleted_at timestamptz
}

Table purchase_orders {
  id uuid [pk]
  tenant_id uuid [not null, ref: > tenants.id]
  supplier_id uuid [not null, ref: > suppliers.id]
  status text [not null, default: 'draft']
  total_usd numeric(19,2) [not null, default: 0]
  notes text
  created_by uuid [not null, ref: > auth.users.id]
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
  deleted_at timestamptz
}

Table purchase_order_items {
  id uuid [pk]
  order_id uuid [not null, ref: > purchase_orders.id]
  tenant_id uuid [not null, ref: > tenants.id]
  product_id uuid [not null, ref: > products.id]
  product_name text
  quantity integer [not null]
  cost_usd_per_unit numeric(19,2) [not null]
  received_quantity integer [not null, default: 0]
  total_usd numeric(19,2) [not null]
  created_at timestamptz [default: `now()`]
  deleted_at timestamptz
}

// ===== POS (SALES) =====

Table sales {
  id uuid [pk]
  tenant_id uuid [not null, ref: > tenants.id]
  user_id uuid [not null, ref: > auth.users.id]
  payment_method text [not null]
  subtotal_bs numeric(19,2) [not null]
  igtf_bs numeric(19,2) [not null, default: 0]
  iva_bs numeric(19,2) [not null, default: 0]
  total_bs numeric(19,2) [not null]
  exchange_rate numeric(19,4) [not null]
  status text [not null, default: 'completed']
  voided_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
}

Table sale_items {
  id uuid [pk]
  sale_id uuid [not null, ref: > sales.id]
  tenant_id uuid [not null, ref: > tenants.id]
  product_id uuid [not null, ref: > products.id]
  product_name text
  product_sku text
  quantity numeric(19,2) [not null]
  unit_price_usd numeric(19,2) [not null]
  total_price_usd numeric(19,2) [not null]
  cost_usd_per_unit numeric(19,2)
  is_weighted boolean [not null, default: false]
  unit text
  created_at timestamptz [not null, default: `now()`]
}

Table cash_registers {
  id uuid [pk]
  tenant_id uuid [not null, ref: > tenants.id]
  is_open boolean [not null, default: false]
  opened_by uuid [ref: > auth.users.id]
  opened_at timestamptz
  opening_balance_bs numeric(19,2)
  opening_rate numeric(19,2)
  closed_by uuid [ref: > auth.users.id]
  closed_at timestamptz
  closing_balance_bs numeric(19,2)
  expected_closing_bs numeric(19,2)
  difference_bs numeric(19,2)
  total_sales_count integer [not null, default: 0]
  total_sales_bs numeric(19,2) [not null, default: 0]
  total_igtf_bs numeric(19,2) [not null, default: 0]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz
  deleted_at timestamptz
}

// Refs
Ref: user_roles.tenant_id - tenants.id
Ref: subscriptions.tenant_id - tenants.id
Ref: audit_trail.tenant_id - tenants.id
Ref: exchange_rates.tenant_id - tenants.id
Ref: products.tenant_id - tenants.id
Ref: products.category_id - categories.id
Ref: categories.tenant_id - tenants.id
Ref: inventory_movements.tenant_id - tenants.id
Ref: inventory_movements.product_id - products.id
Ref: inventory_movements.user_id - auth.users.id
Ref: inventory_lots.tenant_id - tenants.id
Ref: inventory_lots.product_id - products.id
Ref: inventory_lots.source_movement_id - inventory_movements.id
Ref: suppliers.tenant_id - tenants.id
Ref: purchase_orders.tenant_id - tenants.id
Ref: purchase_orders.supplier_id - suppliers.id
Ref: purchase_order_items.order_id - purchase_orders.id
Ref: purchase_order_items.tenant_id - tenants.id
Ref: purchase_order_items.product_id - products.id
Ref: sales.tenant_id - tenants.id
Ref: sales.user_id - auth.users.id
Ref: sale_items.sale_id - sales.id
Ref: sale_items.tenant_id - tenants.id
Ref: sale_items.product_id - products.id
Ref: cash_registers.tenant_id - tenants.id
