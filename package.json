{
  "name": "logiscore-erp",
  "version": "0.1.0",
  "private": true,
  "description": "LogisCore ERP - Sistema de gestión para PYMES y bodegas en Venezuela",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean",
    "new:plan": "node scripts/create-plan.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "new:module": "node scripts/new-module.mjs"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "turbo": "^2.9.10",
    "typescript": "^6.0.3"
  },
  "packageManager": "npm@11.4.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0"
  }
}
